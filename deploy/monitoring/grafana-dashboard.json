{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "cogno-chain",
  "uid": "cogno-chain",
  "schemaVersion": 39,
  "version": 2,
  "tags": ["cogno-chain"],
  "timezone": "",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "${DS_PROMETHEUS}" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Chain height (best vs finalized)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "substrate_block_height{job=\"cogno-node\",status=\"best\"}", "legendFormat": "best" },
        { "expr": "substrate_block_height{job=\"cogno-node\",status=\"finalized\"}", "legendFormat": "finalized" }
      ]
    },
    {
      "id": 2,
      "title": "Observer — observations vs abstains (per s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "rate(cogno_observer_observations_total{job=\"cogno-node\"}[5m])", "legendFormat": "observations/s" },
        { "expr": "rate(cogno_observer_abstains_total{job=\"cogno-node\"}[5m])", "legendFormat": "abstains/s" }
      ]
    },
    {
      "id": 3,
      "title": "Node up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "up{job=\"cogno-node\"}", "legendFormat": "node" }
      ]
    },
    {
      "id": 4,
      "title": "Observed entries (vaults / voters)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "targets": [
        { "expr": "cogno_observer_observed_vaults{job=\"cogno-node\"}", "legendFormat": "vaults" },
        { "expr": "cogno_observer_observed_voters{job=\"cogno-node\"}", "legendFormat": "voters" }
      ]
    },
    {
      "id": 5,
      "title": "Observer reference slot (Cardano)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "cogno_observer_last_reference_slot{job=\"cogno-node\"}", "legendFormat": "reference slot" }
      ]
    },
    {
      "id": 6,
      "title": "Node peers",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "substrate_sub_libp2p_peers_count{job=\"cogno-node\"}", "legendFormat": "peers" }
      ]
    },
    {
      "id": 7,
      "title": "Observer — observed entries over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "cogno_observer_observed_vaults{job=\"cogno-node\"}", "legendFormat": "vaults" },
        { "expr": "cogno_observer_observed_voters{job=\"cogno-node\"}", "legendFormat": "voters" }
      ]
    }
  ]
}
