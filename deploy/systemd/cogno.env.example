# /etc/cogno/cogno.env — systemd EnvironmentFile for the cogno-chain services (node, relayer, follower,
# indexer, query). Copy to /etc/cogno/cogno.env, fill in real values, then lock it down:
#
#     install -o root -g cogno -m 0640 deploy/systemd/cogno.env.example /etc/cogno/cogno.env
#     # ...edit /etc/cogno/cogno.env, then it stays root:cogno 0640 (readable only by the service user)
#
# THIS FILE HOLDS SECRETS (signing seeds, the Postgres password). NEVER commit a filled-in copy.
# Every variable mirrors a documented override in the repo's root .env.example.

# ── data dir ────────────────────────────────────────────────────────────────────────────
# systemd StateDirectory=cogno already creates /var/lib/cogno (0700, cogno:cogno); the units also set
# COGNO_DATA_DIR=/var/lib/cogno explicitly. The relayer wallet, anchor cursor, committee vault and the
# single-instance lock all live here. Leave this as /var/lib/cogno under systemd.
COGNO_DATA_DIR=/var/lib/cogno

# ── chain (local node RPC) ──────────────────────────────────────────────────────────────
WS=ws://127.0.0.1:9944
NODE_HTTP=http://127.0.0.1:9944
# Genesis pin: your chain's block-0 hash (chain_getBlockHash[0]). When set, the relayer + committee
# tooling REFUSE to anchor/sign against any other chain (a mis-pointed WS). Strongly recommended on a
# real deployment — set it once the node is up (see deploy/README.md "Verify").
# GENESIS=0x...

# ── cardano: db-sync (the in-protocol observation source) ────────────────────────────────
# Read-only Cardano db-sync (Postgres) — the SOLE source of the in-protocol observation (D4). The NODE's
# observer reads the talk_vault here, as do the committee sync-weight/shadow-diff and the follower (the
# deterministic block-at/before-slot anchor + the vault UTxO read: spentness from tx_in, coins as ::text,
# driven from the indexed payment_cred). The node picks this up via EnvironmentFile in cogno-node.service.
# Absent / unset ⇒ the observer ABSTAINS (chain still produces). MAINNET PREREQUISITE: db-sync FULL
# (non-pruned, retaining history back to the reference), tx_in-enabled (NOT --consumed-tx-out — the read
# probes EXISTS(SELECT 1 FROM tx_in) and abstains fail-closed otherwise), and over TLS.
DBSYNC_URL=postgres://cogno_reader:PASSWORD@127.0.0.1:5432/cexplorer

# ── cardano: Kupo + Ogmios (the L1 WRITE path only — RETIRED from observation) ────────────
# Used by the anchor-relayer (wallet UTxO selection + /metadata confirm) and the in-browser CIP-30 vault;
# Ogmios also submits L1 txs + serves cost models. NOT read by the node/observer (that is db-sync, above).
KUPO=http://127.0.0.1:1442
OGMIOS=http://127.0.0.1:1337

# ── privileged signing (authority model: committee-routed, sudo offline as break-glass) ──
# The relayer (ANCHOR_VIA=committee) routes privileged writes (anchor_ack, set_stake, validators, and
# the gate `revoke` ban) through the 3-of-5 FollowerCommittee using COMMITTEE_SEEDS, so it does not hold
# the chain's full sudo key. (D1: identity BINDING no longer needs a privileged signer at all — it is the
# permissionless on-chain `link_identity_signed` self-proof; the follower writes nothing.) Each seed is a
# mnemonic or a //derivation URI; on a real chain these are the keys you seated in genesis (gen-chainspec
# writes network/env.sh for you). Keep SUDO_SEED OFFLINE — it is a break-glass key only.
ANCHOR_VIA=committee
COMMITTEE_SEEDS=
# COGNO_PROFILE=prod refuses the public dev keys (//Alice…) for any privileged signing — set it so a
# misconfigured COMMITTEE_SEEDS fails loudly instead of signing with public keys.
COGNO_PROFILE=prod
# SUDO_SEED=   # break-glass ONLY — keep offline; set temporarily for an emergency sudo op, then remove.

# ── relayer tunables ────────────────────────────────────────────────────────────────────
ANCHOR_EVERY=10
# Reorg-burial depth in Cardano slots before an anchor is acked. 0 = NO reorg protection (dev only);
# a value-bearing/preprod-as-prod deployment should set a few hundred slots (DR-09b).
CONFIRM_DEPTH_SLOTS=120
# Observability (Phase 2): /metrics + /healthz on this port (0 disables); Prometheus scrapes
# 127.0.0.1:9101. Warn + expose cogno_relayer_low_funds=1 below LOW_FUNDS_LOVELACE wallet balance.
METRICS_PORT=9101
LOW_FUNDS_LOVELACE=10000000

# ── follower (D1: read-only helper — /health, /metrics, /nonce; it writes NOTHING) ───────────
PORT=8090
HOST=127.0.0.1                 # bind localhost; put public access behind a TLS reverse proxy
CORS_ORIGIN=*                  # set to your frontend origin in production
RATE_LIMIT_PER_MIN=60          # per-IP req/min on /nonce (0=off)
# The follower needs no signing key, no WS, and no Node submitter (D1 retired the bind-WRITE); it only
# reads the node genesis via NODE_HTTP for the /nonce payload + the /health probe.

# ── indexer / query (Postgres) ──────────────────────────────────────────────────────────
DB_USER=cogno
DB_PASS=
DB_DATABASE=cogno_indexer
DB_HOST=127.0.0.1
DB_PORT=5432
