# /etc/cogno/cogno.env — systemd EnvironmentFile for the cogno-chain services (relayer, follower,
# indexer, query). Copy to /etc/cogno/cogno.env, fill in real values, then lock it down:
#
#     install -o root -g cogno -m 0640 deploy/systemd/cogno.env.example /etc/cogno/cogno.env
#     # ...edit /etc/cogno/cogno.env, then it stays root:cogno 0640 (readable only by the service user)
#
# THIS FILE HOLDS SECRETS (signing seeds, the Postgres password). NEVER commit a filled-in copy.
# Every variable mirrors a documented override in the repo's root .env.example.

# ── data dir ────────────────────────────────────────────────────────────────────────────
# systemd StateDirectory=cogno already creates /var/lib/cogno (0700, cogno:cogno); the units also set
# COGNO_DATA_DIR=/var/lib/cogno explicitly. The relayer wallet, anchor cursor, committee vault and the
# single-instance lock all live here. Leave this as /var/lib/cogno under systemd.
COGNO_DATA_DIR=/var/lib/cogno

# ── chain (local node RPC) ──────────────────────────────────────────────────────────────
WS=ws://127.0.0.1:9944
NODE_HTTP=http://127.0.0.1:9944

# ── cardano observers ───────────────────────────────────────────────────────────────────
KUPO=http://127.0.0.1:1442
OGMIOS=http://127.0.0.1:1337

# ── privileged signing (authority model: committee-routed, sudo offline as break-glass) ──
# Route all routine privileged writes through the 3-of-5 FollowerCommittee. Each seed is a mnemonic or
# a //derivation URI; on a real chain these are the keys you seated in genesis (gen-chainspec writes
# network/env.sh for you). Keep SUDO_SEED OFFLINE (commented out) — set it only for an emergency
# break-glass op, then remove it again.
ANCHOR_VIA=committee
COMMITTEE_SEEDS=
# SUDO_SEED=
# NOTE: the cogno-follower signs link_identity with SUDO_SEED (Phase 3 moves it to FollowerOrigin). To
# run the follower on an operator-keyed chain you MUST set SUDO_SEED above for now (it then holds root);
# every bind fails BadOrigin otherwise. Leave it commented only if you are not running the follower.

# ── relayer tunables ────────────────────────────────────────────────────────────────────
ANCHOR_EVERY=10
# Reorg-burial depth in Cardano slots before an anchor is acked. 0 = NO reorg protection (dev only);
# a value-bearing/preprod-as-prod deployment should set a few hundred slots (DR-09b).
CONFIRM_DEPTH_SLOTS=120

# ── follower ────────────────────────────────────────────────────────────────────────────
PORT=8090
# NODE_BIN is set in cogno-follower.service to /usr/local/bin/node (a real, non-snap node v22).

# ── indexer / query (Postgres) ──────────────────────────────────────────────────────────
DB_USER=cogno
DB_PASS=
DB_DATABASE=cogno_indexer
DB_HOST=127.0.0.1
DB_PORT=5432
