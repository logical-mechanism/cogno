# /etc/cogno/cogno.env — systemd EnvironmentFile for the cogno-chain services (relayer, follower,
# indexer, query). Copy to /etc/cogno/cogno.env, fill in real values, then lock it down:
#
#     install -o root -g cogno -m 0640 deploy/systemd/cogno.env.example /etc/cogno/cogno.env
#     # ...edit /etc/cogno/cogno.env, then it stays root:cogno 0640 (readable only by the service user)
#
# THIS FILE HOLDS SECRETS (signing seeds, the Postgres password). NEVER commit a filled-in copy.
# Every variable mirrors a documented override in the repo's root .env.example.

# ── data dir ────────────────────────────────────────────────────────────────────────────
# systemd StateDirectory=cogno already creates /var/lib/cogno (0700, cogno:cogno); the units also set
# COGNO_DATA_DIR=/var/lib/cogno explicitly. The relayer wallet, anchor cursor, committee vault and the
# single-instance lock all live here. Leave this as /var/lib/cogno under systemd.
COGNO_DATA_DIR=/var/lib/cogno

# ── chain (local node RPC) ──────────────────────────────────────────────────────────────
WS=ws://127.0.0.1:9944
NODE_HTTP=http://127.0.0.1:9944
# Genesis pin: your chain's block-0 hash (chain_getBlockHash[0]). When set, the relayer + committee
# tooling + follower REFUSE to anchor/sign against any other chain (a mis-pointed WS). Strongly
# recommended on a real deployment — set it once the node is up (see deploy/README.md "Verify").
# GENESIS=0x...

# ── cardano observers ───────────────────────────────────────────────────────────────────
KUPO=http://127.0.0.1:1442
OGMIOS=http://127.0.0.1:1337

# ── privileged signing (authority model: committee-routed, sudo offline as break-glass) ──
# BOTH the relayer (ANCHOR_VIA=committee) AND the follower (FOLLOWER_VIA=committee) route privileged
# writes through the 3-of-5 FollowerCommittee using COMMITTEE_SEEDS, so neither holds the chain's full
# sudo key. Each seed is a mnemonic or a //derivation URI; on a real chain these are the keys you seated
# in genesis (gen-chainspec writes network/env.sh for you). Keep SUDO_SEED OFFLINE — it is a break-glass
# key only; the routine paths never use it.
ANCHOR_VIA=committee
FOLLOWER_VIA=committee
COMMITTEE_SEEDS=
# COGNO_PROFILE=prod refuses the public dev keys (//Alice…) for any privileged signing — set it so a
# misconfigured COMMITTEE_SEEDS fails loudly instead of signing with public keys.
COGNO_PROFILE=prod
# SUDO_SEED=   # break-glass ONLY — keep offline; set temporarily for an emergency sudo op, then remove.

# ── relayer tunables ────────────────────────────────────────────────────────────────────
ANCHOR_EVERY=10
# Reorg-burial depth in Cardano slots before an anchor is acked. 0 = NO reorg protection (dev only);
# a value-bearing/preprod-as-prod deployment should set a few hundred slots (DR-09b).
CONFIRM_DEPTH_SLOTS=120
# Observability (Phase 2): /metrics + /healthz on this port (0 disables); Prometheus scrapes
# 127.0.0.1:9101. Warn + expose cogno_relayer_low_funds=1 below LOW_FUNDS_LOVELACE wallet balance.
METRICS_PORT=9101
LOW_FUNDS_LOVELACE=10000000

# ── follower ────────────────────────────────────────────────────────────────────────────
PORT=8090
HOST=127.0.0.1                 # bind localhost; put public access behind a TLS reverse proxy
CORS_ORIGIN=*                  # set to your frontend origin in production
MAX_BODY_BYTES=16384           # /bind body cap
MAX_INFLIGHT=4                 # concurrent /bind subprocess forks
RATE_LIMIT_PER_MIN=30          # per-IP req/min on /bind + /nonce (0=off)
SUBMIT_TIMEOUT=150             # max s for a committee bind (propose+votes+close); timeout → 202 pending
# NODE_BIN is set in cogno-follower.service to /usr/local/bin/node (a real, non-snap node v22).

# ── indexer / query (Postgres) ──────────────────────────────────────────────────────────
DB_USER=cogno
DB_PASS=
DB_DATABASE=cogno_indexer
DB_HOST=127.0.0.1
DB_PORT=5432
