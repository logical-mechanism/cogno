# cogno-chain — environment manifest (safe defaults; no secrets in this file).
#
# Every variable below is actually read somewhere in the repo (verified by grepping
# process.env in services/*/*.mjs + app/scripts/*.mjs + app/src/lib, and os.environ in
# services/cogno-follower/*.py). All have built-in code defaults — these are overrides.
#
# This file is the COMMITTED manifest. Real/local values go in untracked .env files:
#   - DB creds for the indexer live in services/indexer/.env (see services/indexer/.env.example)
#   - everything else is normally exported in your shell or a local, gitignored .env.
# Nothing here is a secret; the only secret in the project (the indexer DB password) is
# documented as a placeholder in services/indexer/.env.example, not here.

# ───────────────────────────── chain (Substrate app-chain) ─────────────────────────────
WS=ws://127.0.0.1:9944                 # node WebSocket RPC; read by nearly every .mjs + follower.py
NODE_HTTP=http://127.0.0.1:9944        # node HTTP RPC; follower.py only
# Genesis hash pin. Scripts default to GENESIS.txt or a baked-in hash; override on a fresh
# --dev rebuild (genesis changes). Leave unset to use each script's own default.
GENESIS=

# ──────────────────────────────────── cardano (L1) ────────────────────────────────────
KUPO=http://127.0.0.1:1442             # Kupo chain indexer (UTxO/datum/asset queries)
OGMIOS=http://127.0.0.1:1337           # Ogmios bridge (cost models, submit, ledger tip)
# Cardano db-sync (read-only Postgres). Source of the in-protocol-observation block-by-slot ANCHOR
# (the deterministic "block at/before slot S" that Kupo /checkpoints cannot give), and the
# consolidation target for the vault read. Real creds go in the gitignored .env (DBSYNC_URL|DBSYNC).
DBSYNC_URL=postgres://cogno_reader:PASSWORD@HOST:5432/cexplorer
POSTER=//CognoVaultPoster              # sr25519 dev URI that signs feeless posts (the post key)
LOCK=100000000                         # lovelace to lock in the vault (100 ADA == min_lock); app/scripts demo
TEXT=                                  # demo post body for the live-loop scripts (unset = script default)
MNEMONIC=                              # test wallet mnemonic for demo scripts; unset = baked-in test phrase (NO FUNDS)

# ───────────────────────── follower (services/cogno-follower) ──────────────────────────
PORT=8090                              # follower HTTP listen port
HOST=127.0.0.1                         # bind host (put it behind a TLS reverse proxy for public access)
NONCE_TTL=300                          # seconds a CIP-8 bind nonce stays valid
APP_DIR=                               # path to app/ for shared node deps; unset = ../../app (resolved)
COGNO_FOLLOWER_PY=                     # follower venv python; unset = services/cogno-follower/.venv/bin/python
NODE_BIN=node                          # node the follower's submit subprocess runs; MUST be a real node
                                       # v22 (the snap `node` writes stdout to /dev/null). Set an absolute
                                       # path on a host where PATH `node` resolves to the snap.
# Submit path: committee (default — follower holds COMMITTEE_SEEDS, NOT the full sudo key) | sudo (dev).
FOLLOWER_VIA=committee
# Transport hardening (follower): cap body size, bound concurrent /bind subprocess forks, per-IP rate
# limit (0=off), and the CORS origin (set to your frontend origin in production; * for the showcase).
MAX_BODY_BYTES=16384
MAX_INFLIGHT=4
RATE_LIMIT_PER_MIN=30
CORS_ORIGIN=*
SUBMIT_TIMEOUT=150                     # max seconds for a committee bind; on timeout the follower 202s
                                       # (submitted, finalization pending — re-query before retrying)
HEALTH_PROBE_TTL=2                     # seconds /health + /metrics cache the node liveness probe, so an
                                       # unthrottled probe flood can't stampede the node with 2s RPCs

# ────────────────── sponsored-bind relay (services/sponsored-bind-relay) ────────────────
# Pays the fee for the trustless on-chain identity bind (cognoGate.link_identity_signed) so a brand-new,
# ZERO-balance posting account can register — closing the D1 bind-funding gap WITHOUT weakening the DoS
# defence (someone always pays). A LIVENESS-only party: the runtime verifies every proof, so the relay
# can never forge or retarget a binding (it can only withhold/censor). NOT the read-only follower — a
# separate funded service. Its own listen PORT (default 8091, vs the follower's 8090), and
# HOST/CORS_ORIGIN/RATE_LIMIT_PER_MIN/HEALTH_PROBE_TTL/SUBMIT_TIMEOUT are read the same way as the
# follower's (SUBMIT_TIMEOUT bounds a non-finalizing bind so a finality stall can't wedge the queue).
RELAY_SEED=//Bob                       # the FUNDED submitter (NOT a privileged key); set a real funded seed in prod
MIN_BALANCE=1000000000                 # planck floor below which /health reports the relay unhealthy (top it up)

# ───────────────────────── committee + relayer (services/committee, services/anchor-relayer) ─────────────────────────
# Signing keys. Default to the well-known dev keys (for --dev / the `local` preset). On YOUR OWN
# network, set these to the keys you seated in genesis — scripts/gen-chainspec.mjs writes both into
# network/env.sh for you to `source`. Each seed is a mnemonic or a `//derivation` URI.
COMMITTEE_SEEDS=//Alice,//Bob,//Charlie,//Dave,//Eve  # the FollowerCommittee seats (origin = ≥3/5)
SUDO_SEED=//Alice                      # the sudo (EnsureRoot) key — must match `sudo.key` in genesis
# Fail-closed profile. COGNO_PROFILE=prod makes the committee tooling + relayer REFUSE to sign with the
# public dev keys (//Alice…) or an unset seed — so a forgotten `source network/env.sh` fails loudly.
COGNO_PROFILE=                         # unset = dev (dev keys allowed); set `prod` on a real deployment
# Privileged tools assert the chain genesis matches the GENESIS pin (see the chain section above) before
# broadcasting, if set — so a mis-pointed WS can't drive a privileged call against the wrong chain.
ACCOUNT=//CognoVaultPoster             # sync-weight: app-chain account whose stake is set from the vault
IDENTITY=                              # sync-weight: identity hash (beacon name) to bind; unset = derived
# Durable data dir for stateful files (relayer wallet + anchor cursor + committee vault + locks). The
# systemd StateDirectory=cogno already creates /var/lib/cogno 0700; for a by-hand run leave unset to
# default to ~/.local/state/cogno. NEVER /tmp — a tmpfs clear would drop the funded wallet + cursor.
COGNO_DATA_DIR=                        # unset = ~/.local/state/cogno (or the systemd StateDirectory)
OWNER_FILE=                            # relayer wallet mnemonic file; unset = $COGNO_DATA_DIR/owner.json
COGNO_ALLOW_WALLET_BREW=               # set to 1 ONLY to deliberately brew a NEW wallet (first-time/dev)
VAULT_FILE=                            # locked-vault descriptor; unset = $COGNO_DATA_DIR/vault.json
STATE_FILE=                            # anchor-relayer cursor; unset = $COGNO_DATA_DIR/anchor-state.json
ANCHOR_VIA=committee                   # anchor-relayer write path: committee | sudo
ANCHOR_EVERY=10                        # anchor every N finalized blocks (relayer)
LABEL=67797178                         # Cardano metadata label for anchor txs ("COGN")
VIA=sudo                               # m6-validators add/remove driver: sudo | committee (committee proven in Track 2)
POLL_MS=4000                           # relayer finalized-head poll interval (ms)
CONFIRM_TIMEOUT_MS=180000              # relayer: max wait for a Cardano tx to confirm (ms)
CONFIRM_DEPTH_SLOTS=0                  # relayer: extra slot depth to wait before treating a tx as confirmed

# ──────────────────────────── indexer (services/indexer) ───────────────────────────────
# DB_* are read by the SubQuery indexer. Real values (incl. the password) belong in the
# untracked services/indexer/.env — see services/indexer/.env.example for the schema.
GQL=http://127.0.0.1:3000/             # GraphQL endpoint the M4c verifier queries (verify-m4c.mjs)
DB_USER=cogno                          # Postgres role
DB_PASS=changeme                       # Postgres password (SECRET — keep the real value only in services/indexer/.env)
DB_DATABASE=cogno_indexer              # indexer database name
DB_HOST=127.0.0.1                      # Postgres host (TCP; not a unix socket)
DB_PORT=5432                           # Postgres port

# ──────────────────────────────── frontend (app/, build-time) ──────────────────────────
# NEXT_PUBLIC_* are inlined by Next at build time (app/src/lib/config/endpoints.ts). A user
# override in localStorage always wins over these baked-in defaults at runtime.
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:9944         # default node WS the UI reads/broadcasts through
NEXT_PUBLIC_FOLLOWER_URL=http://127.0.0.1:8090 # default cogno-follower base URL (read-only helper)
NEXT_PUBLIC_BIND_RELAY_URL=http://127.0.0.1:8091 # default sponsored-bind relay (pays the bind fee, D1)
NEXT_PUBLIC_GRAPHQL_URL=http://127.0.0.1:3000/ # default SubQuery GraphQL feed (Tier-B reads)
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=             # Blockfrost preprod project id for the in-browser CIP-30 vault (M8)
