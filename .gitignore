# Rust build output
/target
**/target

# Vendored polkadot-sdk monorepo clone (huge; never a build input — a local reference checkout only,
# re-cloneable at the pinned release tag. The workspace tracks `stable2606`; the original fork point
# is recorded in Cargo.toml.)
/_sdk

# Vendored study checkouts
/_reference
_keys

# Node deps (app + the acceptance / CIP-8 fixture scripts)
node_modules/

# Secrets / local env (never commit real creds). The committed manifests are the *.env.example files;
# every other .env* variant stays local — Next.js also loads `.env.production` / `.env.development`,
# so the glob has to be wider than `.env` + `.env*.local`.
.env*
**/.env*
!.env.example
!**/.env.example

# Python bytecode (ci/cip8-oracle)
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# Editor / OS cruft
*.rs.bk
.DS_Store

# Local coding-agent state (CLAUDE.md lives at the repo root, so contributors will run agent tooling
# here). Their transcripts / settings / scratch are personal and must never ride into a PR.
.claude/

# Local chain state (dev/throwaway runs use --tmp/--dev)
/state
*.log

# Local tracking-node ("relay") DB — scripts/run-tracking-node.sh syncs the real chain here so the
# frontend can read live data. Re-syncable; never commit. (Override the dir with RELAY_BASE=.)
/.relay-data

# Operator secret keys (`cogno-chain-cli key gen` envelopes). NEVER commit the secrets. The
# operator-keyed genesis (`cogno-chain-node gen-chainspec`) bakes in only PUBLIC keys, so the raw
# chainspec itself is not secret — but the .skey / keys.json envelopes that seed it are.
*.skey
**/keys.json

# libp2p node (p2p) key files (`cogno-chain-cli key generate-node-key`). A RAW HEX ed25519 SECRET —
# the node's network identity. Both runbooks mint `val-p2p.key` with a RELATIVE path, i.e. straight
# into the checkout root, so one `git add -A` would publish it. Never commit it.
*.key

# A filled-in systemd EnvironmentFile (DBSYNC_URL + any DB creds) is a local secret; the committed
# manifest is cogno.env.example. (No bare **/vault.json ignore — vault.json is a committed build
# artifact under app/src/lib/cardano/ and contracts/.)
cogno.env
**/cogno.env
!**/cogno.env.example
