# cogno-chain frontend — build-time config seeds
#
# Copy to `.env.local` and adjust for your deployment:
#   cp .env.example .env.local
#
# These NEXT_PUBLIC_* values are inlined by Next at BUILD time (see
# src/lib/config/endpoints.ts). They only seed the DEFAULTS the app ships with —
# a user override saved in Settings (localStorage) always wins over them, which in
# turn wins over the hardcoded localhost fallback. Leaving any of these unset just
# falls back to the localhost dev values below.

# WebSocket endpoint — the app-chain node the SPA reads/writes through (PAPI).
# Default assumes a local `cogno-chain-node --dev` (ws://127.0.0.1:9944). Must be
# ws:// or wss://; a real deployment uses a wss:// public endpoint.
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:9944

# Follower URL — the trusted v1 cogno-follower the CIP-8 bind POSTs to. Must be
# http:// or https://. Default assumes a local follower on :8090.
NEXT_PUBLIC_FOLLOWER_URL=http://127.0.0.1:8090

# GraphQL indexer URL — the optional SubQuery indexer for feed/search/threads.
# Empty ⇒ read directly from the node (PAPI-direct: slower, no search, always
# available). Set to an http(s):// URL to enable indexed reads.
NEXT_PUBLIC_GRAPHQL_URL=

# Blockfrost project id — the PREPROD project id the in-browser vault lock/exit
# txs use. Exposed client-side by design (any visitor can lock from their own
# wallet, no backend). Must be a preprod key. Empty ⇒ the lock action is hidden.
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=
