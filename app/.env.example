# cogno-chain frontend — build-time config seeds
#
# You do NOT need this file to run the app. Left unset, the frontend points at the live public
# preprod endpoint (wss://cogno.forum/rpc), so `npm run dev` and `npm run build` both work on a
# clean clone with zero configuration. Copy it only when you want different defaults:
#   cp .env.example .env.local
#
# These NEXT_PUBLIC_* values are inlined by Next at BUILD time (see src/lib/config/endpoints.ts).
# They seed the DEFAULTS a build ships with; a value the user saves in Settings (localStorage)
# always wins over them.

# WebSocket endpoint — the app-chain node the SPA reads/writes through (PAPI).
#   unset ⇒ wss://cogno.forum/rpc (the live preprod chain).
#   set   ⇒ must be ws:// or wss://. A production `npm run build` additionally REFUSES a plaintext
#           ws:// to a public host (an https page mixed-content-blocks it): use wss://, or
#           ws://127.0.0.1 / ws://localhost when building against your own node.
# NEXT_PUBLIC_WS_URL=ws://127.0.0.1:9944

# Blockfrost project id — the PREPROD project id the in-browser vault lock/exit txs use. Exposed
# client-side by design (any visitor can lock from their own wallet, no backend). Must be a preprod
# key. Empty ⇒ the lock action is hidden.
NEXT_PUBLIC_BLOCKFROST_PROJECT_ID=
