{
  "name": "cogno-chain-app",
  "version": "0.1.0",
  "private": true,
  "description": "cogno-chain M1 frontend — Next.js static-export SPA + PAPI post/read loop (Reading Room / Civic Ledger)",
  "scripts": {
    "postinstall": "papi",
    "dev": "next dev -p 3000",
    "build": "next build",
    "lint": "eslint .",
    "papi:add": "papi add cogno -w ws://127.0.0.1:9944",
    "papi": "papi",
    "test": "vitest run",
    "grant": "node scripts/grant-weight.mjs",
    "acceptance": "node scripts/papi-acceptance.mjs",
    "acceptance:m2c": "node scripts/m2c-acceptance.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@meshsdk/core": "^1.9.1",
    "@meshsdk/core-cst": "^1.9.1",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-labs/hdkd": "^0.0.28",
    "@polkadot-labs/hdkd-helpers": "^0.0.30",
    "blakejs": "^1.2.1",
    "next": "^16.2.10",
    "polkadot-api": "^2.1.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
