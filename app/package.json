    "@polkadot-labs/hdkd-helpers": "^0.0.21",
    "next": "^14.2.15",
    "polkadot-api": "^1.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
