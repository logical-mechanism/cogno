# services/indexer/.env — Postgres credentials for the self-hosted SubQuery indexer (M4).
# Copy this file to `services/indexer/.env` and fill in real values. The real .env is
# gitignored and MUST NOT be committed (it holds the live DB password).
#
# Read by @subql/node + @subql/query (services/indexer) to connect to local Postgres 16.

DB_USER=cogno          # Postgres role the indexer connects as
DB_PASS=changeme       # Postgres password (SECRET — set a real value locally, never commit)
DB_DATABASE=cogno_indexer  # database the indexer writes its event tables into
DB_HOST=127.0.0.1      # Postgres host (TCP — @subql/node rejects unix-socket hosts)
DB_PORT=5432           # Postgres port
